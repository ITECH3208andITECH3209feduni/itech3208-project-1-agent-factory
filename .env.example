# Copy this file to .env and fill in your values
# Never commit .env to git

# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Telegram bot token (required if using Telegram channel)
TELEGRAM_BOT_TOKEN=

# OneCLI gateway (optional — manages credential injection into agent containers)
ONECLI_URL=
ONECLI_API_KEY=
